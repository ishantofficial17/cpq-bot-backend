# LlamaParse (for PDF ingestion — only needed locally)
LLAMA_CLOUD_API_KEY=

# LLM Provider (Groq)
GROQ_API_KEY=

# Models (defaults shown)
# EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# LLM_MODEL=groq:llama-3.1-8b-instant

# Paths (defaults shown)
# PDF_DATA_PATH=data/pdf
# QDRANT_PATH=qdrant_data

# Qdrant Cloud (set both for cloud deployment)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# API Authentication (optional — empty = no auth for dev)
# RAG_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Redis (optional — enables persistent chat memory)
# REDIS_URL=redis://localhost:6379/0
